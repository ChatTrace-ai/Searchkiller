# Google Cloud / Vertex AI
# Local auth: gcloud auth application-default login (no API key needed)
# Cloud Run: service account ADC (roles/aiplatform.user)
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=global

# Exa.ai (Semantic Search)
# Get from: https://dashboard.exa.ai/
EXA_API_KEY=your-exa-api-key

# Elasticsearch Serverless
# Get from: https://cloud.elastic.co/
ES_CLOUD_ID=your-elasticsearch-cloud-id
ES_API_KEY=your-elasticsearch-api-key

# Local proxy (optional — Node fetch does not use these by default; gemini.ts reads them)
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
