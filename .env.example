# Google Cloud / Vertex AI
# Auth: run `gcloud auth application-default login` (no API key needed)
# On Cloud Run: ADC is automatic via the service account
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=us-central1

# Exa.ai (Semantic Search)
# Get from: https://dashboard.exa.ai/
EXA_API_KEY=your-exa-api-key

# Elasticsearch Serverless
# Get from: https://cloud.elastic.co/
ES_CLOUD_ID=your-elasticsearch-cloud-id
ES_API_KEY=your-elasticsearch-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PREDICTION_STREAM_MODE=real

# Featured Predictions
# Set to 'false' to disable auto-refresh of seed predictions on startup
AUTO_REFRESH_FEATURED=true
