{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://g-rapid-agent.local/schemas/trace.schema.json",
  "title": "Execution Trace",
  "description": "A single execution trace record emitted by the Planner and judged by the Evaluator.",
  "type": "object",
  "required": ["id", "agent", "action", "input_hash", "output_hash", "timestamp", "verdict"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^trace-[a-f0-9]{8,}$",
      "description": "Unique trace identifier (trace-<hex>)"
    },
    "agent": {
      "type": "string",
      "enum": ["planner", "evaluator"],
      "description": "Which agent emitted or last modified this trace"
    },
    "action": {
      "type": "string",
      "description": "Human-readable description of the action performed"
    },
    "input_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of the input payload"
    },
    "output_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of the output payload"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of trace creation"
    },
    "verdict": {
      "type": "string",
      "enum": ["PENDING", "AWAITING_HUMAN", "APPROVED", "REJECTED"],
      "description": "Current evaluation state of this trace"
    },
    "metadata": {
      "type": "object",
      "description": "Optional agent-specific metadata",
      "properties": {
        "keyword": { "type": "string" },
        "sub_queries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_count": { "type": "integer", "minimum": 0 },
        "model": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
