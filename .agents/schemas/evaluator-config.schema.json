{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://searchkiller.local/schemas/evaluator-config.schema.json",
  "title": "Evaluator Configuration",
  "description": "Human-defined configuration that initializes the Evaluator via HITL. Once written, the Evaluator runs autonomously using these criteria.",
  "type": "object",
  "required": ["initialized_by", "initialized_at", "criteria", "thresholds"],
  "properties": {
    "initialized_by": {
      "type": "string",
      "description": "Identifier of the human who configured this Evaluator instance"
    },
    "initialized_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of initialization"
    },
    "criteria": {
      "type": "object",
      "required": ["require_schema_valid", "require_output_non_empty", "reject_known_failure_patterns"],
      "properties": {
        "require_schema_valid": {
          "type": "boolean",
          "description": "Reject traces that fail schema validation"
        },
        "require_output_non_empty": {
          "type": "boolean",
          "description": "Reject traces with empty output hashes"
        },
        "reject_known_failure_patterns": {
          "type": "boolean",
          "description": "Reject traces matching known failure patterns in .agents/failures/"
        },
        "custom_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "field", "operator", "value"],
            "properties": {
              "name": { "type": "string" },
              "field": { "type": "string", "description": "Dot-path into trace metadata (e.g. metadata.duration_ms)" },
              "operator": { "type": "string", "enum": ["lt", "gt", "eq", "neq", "contains"] },
              "value": { "description": "Comparison value (type matches field)" }
            }
          },
          "description": "Human-defined custom evaluation rules"
        }
      }
    },
    "thresholds": {
      "type": "object",
      "properties": {
        "max_latency_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum acceptable latency in milliseconds"
        },
        "min_source_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum number of sources required"
        },
        "min_quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum passing quality score (0-1)"
        }
      }
    },
    "auto_approve": {
      "type": "boolean",
      "default": true,
      "description": "When true, traces passing all criteria are auto-approved. When false, only auto-reject is enabled."
    },
    "notes": {
      "type": "string",
      "description": "Human notes about why these criteria were chosen"
    }
  },
  "additionalProperties": false
}
